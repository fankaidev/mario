{
  "name": "mario",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm build:web && wrangler dev",
    "typecheck": "tsgo --noEmit -p tsconfig.worker.json & tsgo --noEmit -p web/tsconfig.json & wait",
    "build:web": "vite build --config web/vite.config.ts",
    "build": "pnpm typecheck && pnpm build:web",
    "check": "pnpm lint & pnpm format:check & pnpm typecheck & pnpm build:web & wait && vitest run",
    "test": "pnpm build:web && vitest run",
    "deploy": "pnpm build && wrangler deploy",
    "prepare": "lefthook install",
    "lint": "oxlint .",
    "format": "oxfmt --write '**/*.{ts,tsx,json,sql}'",
    "format:check": "oxfmt --check '**/*.{ts,tsx,json,sql}'"
  },
  "dependencies": {
    "@cloudflare/vite-plugin": "^1.7.5",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tailwindcss/vite": "^4.1.18",
    "@tanstack/react-query": "^5.100.6",
    "@vitejs/plugin-react": "^5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.10.7",
    "jose": "^6.2.3",
    "lucide-react": "^1.14.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260425.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "better-sqlite3": "^12.9.0",
    "lefthook": "^1.13.6",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.29.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.54.0"
  },
  "packageManager": "pnpm@10.26.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  }
}
